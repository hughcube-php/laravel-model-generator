{
    "name": "hughcube/laravel-model-generator",
    "description": "Laravel Eloquent Model Generator - generate model files from database schema.",
    "keywords": ["laravel", "eloquent", "model", "generator"],
    "homepage": "https://github.com/hughcube-php/laravel-model-generator",
    "support": {
        "issues": "https://github.com/hughcube-php/laravel-model-generator/issues",
        "source": "https://github.com/hughcube-php/laravel-model-generator"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Cristian Llanos",
            "email": "cristianllanos@outlook.com",
            "role": "Original Author"
        },
        {
            "name": "Hugh Li",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.1",
        "doctrine/dbal": "^3.0|^4.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.0",
        "mockery/mockery": "^1.4",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Reliese\\": "src/"
        }
    },
    "autoload-dev": {
        "classmap": [
            "tests/TestCase.php"
        ]
    },
    "config": {
        "preferred-install": "dist"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Reliese\\Coders\\CodersServiceProvider"
            ]
        }
    }
}
